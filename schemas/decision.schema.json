{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/cognitive-os-v0/decision.schema.json",
  "title": "Cognitive OS decision",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "status", "chosen", "why", "reopen_if", "approved_by", "approved_at"],
  "properties": {
    "id": {"type": "string", "pattern": "^DEC-[0-9]{4}-[0-9]{3}$"},
    "type": {"const": "decision"},
    "status": {"enum": ["proposed", "active", "superseded", "closed"]},
    "chosen": {"type": "string", "minLength": 1},
    "not_chosen": {"type": "array", "items": {"type": "string"}},
    "why": {"type": "string", "minLength": 1},
    "evidence_ids": {"type": "array", "items": {"type": "string", "pattern": "^EVD-[0-9]{4}-[0-9]{3}$"}},
    "review_packet_id": {"type": ["string", "null"], "pattern": "^RP-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{3}$"},
    "residual_risk": {"type": "string"},
    "reopen_if": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "supersedes": {"type": ["string", "null"]},
    "approved_by": {"type": "string", "minLength": 1},
    "approved_at": {"type": "string", "format": "date"},
    "commit": {"type": ["string", "null"]}
  }
}
