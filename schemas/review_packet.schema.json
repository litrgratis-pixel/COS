{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/cognitive-os-v0/review_packet.schema.json",
  "title": "Cognitive OS review packet",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "mode", "goal", "stakes", "claims", "verdict", "residual_risk", "human_decision"],
  "properties": {
    "id": {"type": "string", "pattern": "^RP-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{3}$"},
    "mode": {"enum": ["LITE", "STANDARD", "CRITICAL"]},
    "goal": {"type": "string", "minLength": 1},
    "stakes": {"enum": ["low", "medium", "high", "critical"]},
    "reversibility": {"enum": ["reversible", "partly_reversible", "irreversible"]},
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text", "type", "evidence", "confidence"],
        "properties": {
          "id": {"type": "string", "pattern": "^C-[0-9]{3}$"},
          "text": {"type": "string", "minLength": 1},
          "type": {"enum": ["FACT", "HYPOTHESIS", "PREFERENCE", "RECOMMENDATION", "DECISION"]},
          "evidence": {"type": "array", "items": {"type": "string"}},
          "confidence": {"enum": ["low", "medium", "high"]},
          "falsifier": {"type": "string"}
        }
      }
    },
    "assumptions": {"type": "array", "items": {"type": "string"}},
    "alternatives": {"type": "array", "items": {"type": "string"}},
    "independence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model": {"type": "string"},
        "context": {"type": "string"},
        "objective": {"type": "string"},
        "tools": {"type": "string"},
        "order_blinded": {"type": "boolean"}
      }
    },
    "findings": {"type": "array", "items": {"type": "string"}},
    "external_checks": {"type": "array", "items": {"type": "string"}},
    "disagreements": {"type": "array", "items": {"type": "string"}},
    "verdict": {"enum": ["PASS", "REVISE", "NEEDS_EVIDENCE", "DISAGREEMENT", "ESCALATE", "FAIL"]},
    "residual_risk": {"type": "string", "minLength": 1},
    "human_decision": {"enum": ["accept", "reject", "park", "escalate", "pending"]},
    "approved_by": {"type": ["string", "null"]},
    "approved_at": {"type": ["string", "null"], "format": "date"}
  }
}
