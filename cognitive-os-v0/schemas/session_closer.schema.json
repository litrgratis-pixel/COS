{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/cognitive-os-v0/session_closer.schema.json",
  "title": "Cognitive OS session closer",
  "type": "object",
  "additionalProperties": false,
  "required": ["session_id", "date", "status", "next_step", "state_change"],
  "properties": {
    "session_id": {"type": "string", "pattern": "^SES-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{3}$"},
    "date": {"type": "string", "format": "date"},
    "status": {"enum": ["draft", "approved", "abandoned"]},
    "decisions": {"type": "array", "items": {"type": "string"}},
    "rejected": {"type": "array", "items": {"type": "string"}},
    "parking": {"type": "array", "items": {"type": "string"}},
    "backlog": {"type": "array", "items": {"type": "string"}},
    "evidence": {"type": "array", "items": {"type": "string"}},
    "incidents": {"type": "array", "items": {"type": "string"}},
    "state_change": {"type": "boolean"},
    "next_step": {"type": "string", "minLength": 1},
    "protocol_minutes": {"type": ["number", "null"], "minimum": 0},
    "work_minutes": {"type": ["number", "null"], "minimum": 0},
    "approved_by": {"type": ["string", "null"]}
  }
}
